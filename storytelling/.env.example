# ElevenLabs API Configuration
ELEVENLABS_API_KEY=sk_*****

# Set to true to generate silent MP3 placeholders instead of calling the API.
# Use this when working on design/UI to preserve ElevenLabs credits.
ELEVENLABS_MOCK=false

# Audio file server port (background server started by the audio tool)
# Audio files are served at http://localhost:AUDIO_SERVER_PORT/{filename}
AUDIO_SERVER_PORT=8001

# Base URL for audio files (points to the audio file server)
# Change this to your production domain when deploying
APP_BASE_URL=http://localhost:8001

# === Mistral API (story writing + image generation + character DNA) ===
MISTRAL_API_KEY=
IMAGE_PROVIDER=mistral_imagegen

# === Output ===
OUTPUT_DIR=/tmp/storytime_images
LOG_LEVEL=INFO
